# Copy to .env.development, .env.homolog, or .env.production and fill in.
# Never commit a populated env file — `.env*` is gitignored.

NODE_ENV=
PORT=

# Host UID/GID used as Docker build args (must match the host "apps" user — typically 1003)
HOST_UID=
HOST_GID=

# LDAP — used by /api/login (LoginService)
LDAP_SERVER=
LDAP_PORT=
LDAP_PASSWORD=
LDAP_BASE=
LDAP_BIND_DN=
LDAP_UID=

# Demeter database (Prisma)
DATABASE_URL=
DATABASE_URL_CAFE=
DB_PASS=

# Service-to-service JWT signing secret (Bearer token verified in auth middleware)
SERVICE_TOKEN=

# Paths (host-side)
HOME_FOLDER=
LOGS_FOLDER=
